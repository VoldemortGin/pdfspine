    @property
    def size(self) -> int: ...
    @property
    def samples_mv(self) -> memoryview: ...
    def pixel(self, x: int, y: int) -> tuple[int, ...]: ...
    def set_pixel(self, x: int, y: int, value: Sequence[int]) -> None: ...
    def set_alpha(self, value: int) -> None: ...
    def clear_with(self, value: int = ...) -> None: ...
