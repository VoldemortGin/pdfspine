"""Type stubs for the native ``oxide_pdf._core`` extension module (PyO3).

These describe the raw Rust-backed surface. Most user code uses the
:mod:`oxide_pdf.document` wrappers instead; the ``Pixmap`` and ``DisplayList``
classes below are, however, re-exported unwrapped as the public types.
"""

from typing import Any, Iterator, Sequence, final

__version__: str
__all__ = [
    "__version__",
    "version",
    "identity_matrix",
    "open",
    "open_bytes",
    "Document",
    "Page",
    "TextPage",
    "Annot",
    "Widget",
    "Shape",
    "Pixmap",
    "DisplayList",
    "TableFinder",
    "Table",
    "PdfError",
    "PdfSyntaxError",
    "PdfPasswordError",
    "PdfUnsupportedError",
    "PdfDecodeError",
    "PdfLimitError",
    "PdfRedactionError",
]

